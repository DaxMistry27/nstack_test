// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  COMPLETED
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(USER)
  tasks         Task[]
  tokenStorages TokenStorage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id      Int    @id @default(autoincrement())
  title   String
  content String
  status Status @default(PENDING)
  userId  Int

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenStorage {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  accessToken      String?
  accessCreatedAt  DateTime
  accessExpiredAt  DateTime
  refreshToken     String?
  refreshCreatedAt DateTime
  refreshExpiredAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}